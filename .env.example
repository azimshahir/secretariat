# ============================================
# secretariat.my - Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- AI / LLM ---
# Primary LLM (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Secondary LLM / Whisper STT (OpenAI)
OPENAI_API_KEY=sk-your-key-here
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-key-here
HUGGINGFACE_TOKEN=hf_your_token_here
DIARIZATION_MODEL=pyannote/speaker-diarization-3.1

# --- AI Model Configuration ---
# Default provider if no admin override exists (anthropic | openai | google)
AI_PROVIDER=anthropic
# Options include:
# - Anthropic: claude-sonnet-4-5-20250929, claude-opus-4-6
# - OpenAI: gpt-5, gpt-5-mini, gpt-4.1
# - Google: gemini-2.5-pro, gemini-2.5-flash
AI_MODEL=claude-sonnet-4-5-20250929
# LLM model for Minute of Meeting section matching during template import
MOM_FORMAT_SECTION_MODEL=gpt-4.1
# OCR model for minute template parsing (PDF / low-text fallback)
MOM_FORMAT_OCR_MODEL=gpt-4.1-mini
# OCR model for scanned PDF import fallback in Secretariat template import
PDF_IMPORT_OCR_MODEL=gpt-4.1-mini

# --- File Processing ---
# Max upload size in MB
MAX_UPLOAD_SIZE_MB=500

# Auto-purge raw files after meeting finalized (days)
AUTO_PURGE_DAYS=30
PURGE_CRON_SECRET=replace-with-long-random-secret

# --- App Configuration ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=secretariat.my
